{
  "manifest_version": 3,
  "name": "Responsive Viewer",
  "version": "0.6.1",
  "description": "Preview the page you're on at any device resolution, in place. Searchable picker from the toolbar popup. Every preset free, plus custom W x H.",
  "permissions": ["declarativeNetRequestWithHostAccess", "storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN",
      "js": ["emulate.js"]
    }
  ],
  "action": {
    "default_title": "Responsive Viewer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "web_accessible_resources": [
    { "resources": ["viewer.html"], "matches": ["<all_urls>"] }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
